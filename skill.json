{
  "name": "a2a-work-group-nxm",
  "version": "1.0.0",
  "description": "Multi-agent collaboration skill for project initialization, dispatch, ACK tracking, and long-task checkpoint management",
  "author": "qiang",
  "date": "2026-04-21",
  "status": "executable",
  "entry": {
    "cli": "scripts/workgroup_cli.py",
    "python": "scripts/workgroup_run_auto.py"
  },
  "config": {
    "shared_root": "/Volumes/Local Drawer/SharedProjects/",
    "team_role_map": "config/team-role-map.json",
    "default_template": "templates/project-template",
    "path_naming_rule": "english_lowercase_only"
  },
  "dependencies": {
    "python": ">=3.9",
    "openclaw": ">=2026.4.15"
  },
  "permissions": [
    "sessions.send",
    "sessions.get",
    "sessions.list",
    "exec",
    "read",
    "write"
  ]
}

{
  "name": "a2a-work-group-nxm",
  "version": "1.0.1",
  "description": "Multi-agent collaboration skill for OpenClaw: project initialization, routing, dispatch, ACK tracking, and checkpoint management",
  "author": "OpenClaw Team",
  "date": "2026-04-22",
  "status": "public_ready",
  "entry": {
    "cli": "scripts/workgroup_cli.py",
    "python": "scripts/workgroup_run_auto.py"
  },
  "config": {
    "shared_root": "YOUR_SHARED_ROOT",
    "team_role_map": "config/team-role-map.json",
    "default_template": "templates/project-template",
    "path_naming_rule": "english_lowercase_only"
  },
  "dependencies": {
    "python": ">=3.9",
    "openclaw": ">=2026.4.15"
  },
  "permissions": [
    "sessions.send",
    "sessions.get",
    "sessions.list",
    "exec",
    "read",
    "write"
  ]
}
